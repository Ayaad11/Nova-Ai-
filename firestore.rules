rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: messages
    // Fields:
    //   - uid: string (required) - User ID of the owner
    //   - role: string (required) - 'user' or 'assistant'
    //   - content: string (required) - Text content
    //   - type: string (required) - 'text', 'image', or 'audio'
    //   - mediaUrl: string (optional) - URL to media
    //   - createdAt: timestamp (required) - Server timestamp
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    // Domain Validators (CRITICAL: Use these in both create and update)
    function isValidMessage(data) {
      return data.keys().hasAll(['uid', 'role', 'content', 'type', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.role in ['user', 'assistant'] &&
             data.type in ['text', 'image', 'audio'] &&
             data.content is string && data.content.size() > 0 && data.content.size() < 10000 &&
             (!('mediaUrl' in data) || (data.mediaUrl is string && isValidUrl(data.mediaUrl))) &&
             (!('sources' in data) || (data.sources is list && data.sources.size() <= 20));
    }

    match /messages/{messageId} {
      // Users can only read their own messages (PII Protection)
      allow read: if isAuthenticated() && (resource == null || resource.data.uid == request.auth.uid);
      
      // Users can only create messages for themselves with strict validation
      allow create: if isAuthenticated() && isValidMessage(request.resource.data);
      
      // Messages are immutable to prevent history tampering
      allow update: if false;
      
      // Users can delete their own history
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    // Log Validation
    function isValidLog(data) {
      return data.keys().hasAll(['uid', 'type', 'operation', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.type in ['performance', 'error'] &&
             data.operation is string &&
             (!('latency' in data) || data.latency is number) &&
             (!('error' in data) || data.error is string);
    }

    // Feedback Validation
    function isValidFeedback(data) {
      return data.keys().hasAll(['uid', 'rating', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.rating is int && data.rating >= 1 && data.rating <= 5 &&
             (!('comment' in data) || (data.comment is string && data.comment.size() < 1000));
    }

    match /logs/{logId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && isValidLog(request.resource.data);
      allow update, delete: if false;
    }

    match /feedback/{feedbackId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && isValidFeedback(request.resource.data);
      allow update, delete: if false;
    }

    match /preferences/{userId} {
      allow read, write: if isAuthenticated() && userId == request.auth.uid;
    }

    match /subscriptions/{userId} {
      allow read: if isAuthenticated() && userId == request.auth.uid;
      allow write: if false; // Only server-side or admin can update subscriptions
    }

    match /api_keys/{keyId} {
      allow read, write: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
    }

    match /ethics_logs/{logId} {
      allow read: if isAuthenticated(); // Global transparency for ethics
      allow write: if false; // System-only logs
    }

    match /impact_metrics/{metricId} {
      allow read: if true; // Public transparency for global impact
      allow write: if false; // System-only
    }

    match /educational_content/{contentId} {
      allow read: if true; // Public legacy and knowledge transfer
      allow write: if false; // Admin-only
    }

    match /model_configs/{configId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.uid;
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.uid;
      allow update: if isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    match /learning_logs/{logId} {
      allow read: if true; // Public transparency for AI evolution
      allow write: if false; // System-only
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
